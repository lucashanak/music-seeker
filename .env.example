# Spotify API credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# Lidarr (optional - for torrent-based downloads)
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=your_lidarr_api_key

# Music directory
MUSIC_DIR=/music
HOST_MUSIC_DIR=/path/to/your/music/library

# Navidrome (optional - for "In Library" detection)
NAVIDROME_URL=http://navidrome:4533
NAVIDROME_USER=your_navidrome_username
NAVIDROME_PASSWORD=your_navidrome_password

# Docker network (if running alongside other containers)
DOCKER_NETWORK=your_docker_network_name

# Admin credentials (first user created on startup)
ADMIN_USER=admin
ADMIN_PASS=change_me_please

# JWT Secret (optional - auto-generated and persisted if not set)
# JWT_SECRET=your_random_secret_here
