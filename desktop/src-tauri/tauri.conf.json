{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "MusicSeeker",
  "version": "1.0.0",
  "identifier": "org.hanaktech.musicseeker",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MusicSeeker",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 600,
        "url": "https://musicseeker.hanaktech.org",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "android": {
      "minSdkVersion": 24
    }
  },
  "permissions": [
    "core:default"
  ]
}
